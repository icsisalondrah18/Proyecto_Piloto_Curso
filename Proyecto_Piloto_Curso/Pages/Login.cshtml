@page
@model Proyecto_Piloto_Curso.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="row justify-content-center w-100">
        <div class="col-md-5">
            <div class="card shadow-lg border-0" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 text-center pt-4">
                    <h2 class="fw-bold" style="color: #093C5D;">Bienvenido</h2>
                    <p class="text-muted">Ingresa tus credenciales para continuar</p>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.MensajeError))
                    {
                        <div class="alert alert-danger py-2 small text-center">
                            @Model.MensajeError
                        </div>
                    }

                    <form method="post">
                        <div class="form-group mb-3">
                            <label class="fw-bold mb-1 small text-muted">Nombre de usuario</label>
                            <input asp-for="Username" class="form-control" placeholder="Introduce tu usuario" required />
                        </div>

                        <div class="form-group mb-4">
                            <label class="fw-bold mb-1 small text-muted">Contraseña</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Introduce tu contraseña" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                            Iniciar Sesión
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small">¿No tienes cuenta? <a href="/Registro" class="fw-bold text-decoration-none" style="color: #3B7597;">Regístrate aquí</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>