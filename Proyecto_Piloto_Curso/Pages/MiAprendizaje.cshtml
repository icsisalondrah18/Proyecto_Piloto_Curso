@page
@model Proyecto_Piloto_Curso.Pages.MiAprendizajeModel
@{
    ViewData["Title"] = "Mi Aprendizaje";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="fw-bold" style="color: #093C5D;">Mi Aprendizaje</h1>
        <p class="lead text-secondary">Continúa estudiando desde donde lo dejaste</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="alert alert-info alert-dismissible fade show text-center" role="alert">
            @Model.Mensaje
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.CursosInscritos.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-bookmark-fill display-1 text-muted"></i>
            <h3 class="mt-3">Aún no estás inscrito en ningún curso</h3>
            <a href="/Cursos" class="btn btn-primary mt-3">Explorar catálogo</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model.CursosInscritos)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0" style="border-radius: 15px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title fw-bold mb-1">@item.Curso.titulo</h5>
                                    <p class="text-muted small">@item.Curso.CategoriaNavigation?.nombre</p>
                                </div>
                                <span class="badge rounded-pill" style="background-color: #3B7597;">@item.Progreso.ToString("0.00")%</span>
                            </div>

                            <div class="progress mb-3" style="height: 8px; border-radius: 5px;">
                                <div class="progress-bar" role="progressbar" style="width: @item.Progreso%; background-color: #3B7597;"></div>
                            </div>

                            <p class="card-text small text-muted mb-4">
                                Inscrito: @item.FechaInscripcion.ToString("dd/MM/yyyy")
                            </p>

                            <div class="d-flex gap-2">
                                <a href="/CursoDetalle?id=@item.Curso.idCursos" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    Continuar estudiando
                                </a>

                                <form method="post" asp-page-handler="CancelarInscripcion" onsubmit="return confirm('¿Seguro que deseas cancelar la inscripción?');">
                                    <input type="hidden" name="cursoId" value="@item.Curso.idCursos" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                        Cancelar inscripción
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div> @* <--- AQUÍ TERMINA LA FILA DE CURSOS *@

        @* --- BLOQUE DE PAGINACIÓN REPARADO --- *@
        @if (Model.TotalPaginas > 1)
        {
            <nav aria-label="Page navigation" class="mt-4 pb-5">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPaginas; i++)
                    {
                        // Creamos las variables aquí arriba para que el style de abajo sea texto plano
                        var esActiva = (i == Model.PaginaActual);
                        var claseActiva = esActiva ? "active" : "";
                        var colorFondo = esActiva ? "#3B7597" : "white";
                        var colorTexto = esActiva ? "white" : "#3B7597";

                        <li class="page-item @claseActiva" style="margin: 0 5px;">
                            <a class="page-link rounded-circle shadow-sm border-0"
                                   href="?p=@i"
                                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background-color: @colorFondo; color: @colorTexto;">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
        @* --- FIN DEL BLOQUE DE PAGINACIÓN --- *@
    }
</div> @* <--- ESTE CIERRA EL CONTAINER PRINCIPAL *@